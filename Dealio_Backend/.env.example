# Injected automatically by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_REFRESH_SECRET=another_64_char_hex_secret_here

# Server
NODE_ENV=production
PORT=8090

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# SMS (set to TWILIO in prod, CONSOLE in staging to print OTPs to logs)
SMS_PROVIDER=CONSOLE
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google OAuth
GOOGLE_CLIENT_ID=1013744675613-5spva6h3eflij6vvofvjor875iiq9s63.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# File uploads — for production use S3/Cloudflare R2 (local disk is ephemeral on Railway)
# UPLOAD_BUCKET=your-r2-bucket
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY=
# CLOUDFLARE_SECRET_KEY=
